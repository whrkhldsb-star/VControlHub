// TR: AI Knowledge Base / RAG — lexical retrieval over chunked documents.
// Embeddings optional later; current retrieval uses PostgreSQL full-text + ranking.
model KnowledgeBase {
  id          String              @id @default(cuid())
  name        String
  description String?
  isActive    Boolean             @default(true)
  teamId      String?
  team        Team?               @relation("TeamKnowledgeBases", fields: [teamId], references: [id], onDelete: SetNull)
  createdBy   String?
  creator     User?               @relation("KnowledgeBaseCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  documents   KnowledgeDocument[]
  chunks      KnowledgeChunk[]

  @@index([teamId, isActive])
  @@index([createdBy, updatedAt])
  @@map("knowledge_bases")
}

model KnowledgeDocument {
  id             String           @id @default(cuid())
  knowledgeBaseId String
  knowledgeBase  KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  title          String
  sourceType     String           @default("TEXT") // TEXT | MARKDOWN | NOTE
  content        String
  contentHash    String
  status         String           @default("READY") // PENDING | READY | FAILED
  errorMessage   String?
  chunkCount     Int              @default(0)
  createdBy      String?
  creator        User?            @relation("KnowledgeDocumentCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  chunks         KnowledgeChunk[]

  @@index([knowledgeBaseId, updatedAt])
  @@index([contentHash])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id              String            @id @default(cuid())
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase     @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  documentId      String
  document        KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex      Int
  content         String
  tokenEstimate   Int               @default(0)
  // plain text for FTS; generated search vector stored as text keywords for portability
  searchText      String
  createdAt       DateTime          @default(now())

  @@unique([documentId, chunkIndex])
  @@index([knowledgeBaseId, chunkIndex])
  @@map("knowledge_chunks")
}

// FEAT-ITSM-IM-BIDI: ITSM/IM bidirectional integration (ticket <-> external webhook/IM)
model ItsmConnection {
  id             String   @id @default(cuid())
  name           String
  provider       String // generic_webhook | slack | telegram | dingtalk | feishu
  direction      String   @default("bidirectional") // outbound | inbound | bidirectional
  enabled        Boolean  @default(true)
  // Encrypted secrets JSON: webhookSecret, botToken, signingSecret (never returned raw)
  credentialsEnc String   @default("")
  // Plain config: webhookUrl, chatId, defaultPriority, defaultCategory, createOnInbound
  config         Json     @default("{}")
  teamId         String?
  lastOutboundAt DateTime?
  lastInboundAt  DateTime?
  lastError      String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy User?       @relation("ItsmConnectionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  events    ItsmEvent[]

  @@index([provider, enabled])
  @@index([teamId])
  @@index([createdById])
  @@map("itsm_connections")
}

model ItsmEvent {
  id           String   @id @default(cuid())
  connectionId String?
  direction    String // inbound | outbound
  eventType    String
  ticketId     String?
  status       String   @default("pending") // pending | ok | error | ignored
  externalId   String?
  payload      Json     @default("{}")
  errorMessage String?
  createdAt    DateTime @default(now())

  connection ItsmConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@unique([connectionId, externalId])
  @@index([ticketId, createdAt])
  @@index([direction, createdAt])
  @@index([status, createdAt])
  @@map("itsm_events")
}

