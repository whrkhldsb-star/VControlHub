// FEAT-COST-CLOUD-BILLING: 云厂商账单 API 对接
// Stores encrypted credentials for cloud providers and tracks import runs.
// Imported line items land in CostEntry with sourceType=cloud_billing.
model CloudBillingAccount {
  id                 String    @id @default(cuid())
  name               String
  provider           String // aws | aliyun | tencent | generic_csv
  // JSON credentials encrypted via AES-256-GCM (never returned raw to clients).
  credentialsEnc     String
  // Optional path/region/accountId hints for the adapter (plain JSON, no secrets).
  config             Json      @default("{}")
  currency           String    @default("USD")
  enabled            Boolean   @default(true)
  teamId             String? // multi-tenant scope (null = shared/legacy)
  lastSyncAt         DateTime?
  lastSyncStatus     String? // ok | error | partial
  lastSyncError      String?
  lastSyncImported   Int       @default(0)
  lastSyncSkipped    Int       @default(0)
  createdById        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  team      Team?                 @relation("TeamCloudBillingAccounts", fields: [teamId], references: [id], onDelete: SetNull)
  createdBy User?                 @relation("CloudBillingAccountCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
