generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING_PASSWORD_RESET
}

enum ServerConnectionType {
  SSH_KEY
  PASSWORD
}

enum CommandRequestStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ActorType {
  USER
  ASSISTANT
  SYSTEM
}

enum StorageDriver {
  LOCAL
  SFTP
}

enum StorageAccessMode {
  PROXY
  DIRECT
  AUTO
}

enum FileEntryType {
  FILE
  DIRECTORY
}

enum AuditSeverity {
 INFO
 WARNING
 CRITICAL
}

enum AiHostedActionStatus {
 PENDING_APPROVAL
 APPROVED
 REJECTED
 EXECUTING
 COMPLETED
 FAILED
 CANCELLED
}

model User {
  id                 String              @id @default(cuid())
  username           String              @unique
  displayName        String?
  passwordHash       String
  status             UserStatus          @default(PENDING_PASSWORD_RESET)
  mustChangePassword Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  roles              UserRole[]
  storageAccess      UserStorageAccess[]
  commandRequests    CommandRequest[]    @relation("requester")
  jobs               Job[]               @relation("jobCreator")
  approvals          CommandApproval[]
  auditLogs          AuditLog[]
  sshKeys            SshKey[]            @relation("SshKeyCreator")
  notifications      Notification[]
  scheduledTasks     ScheduledTask[]
  playbooks          Playbook[]
  playbookRuns       PlaybookRun[]
  commandTemplates   CommandTemplate[]
  downloadTasks      DownloadTask[]
  syncJobs           SyncJob[]
  shareLinks         ShareLink[]
  backupRecords      BackupRecord[]
  deploymentRuns     DeploymentRun[]
  deploymentRollbackRuns DeploymentRollbackRun[]
  snippets           Snippet[]
  apiTokens          ApiToken[]
  announcements      Announcement[]
  mediaItems         MediaItem[]
 tickets Ticket[] @relation("TicketCreator")
 assignedTickets Ticket[] @relation("TicketAssignee")
 ticketComments TicketComment[]
 imageUploads ImageUpload[]
 deploymentExports DeploymentExport[]
 aiProviders AiProvider[]
 aiConversations AiConversation[]
 aiHostedRequests AiHostedAction[] @relation("AiHostedRequester")
 aiHostedApprovals AiHostedAction[] @relation("AiHostedApprover")
 twoFactorEnabled Boolean @default(false)
 twoFactorSecret String?
 preferences Json?
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model SshKey {
  id          String   @id @default(cuid())
  name        String
  fingerprint String   @unique
  publicKey   String
  privateKey  String?
  description String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User?    @relation("SshKeyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  servers     Server[]
}

model Server {
 id String @id @default(cuid())
 name String
 host String
 port Int @default(22)
 username String
 sshKeyId String?
 password String?
 description String?
 tags String[]
 enabled Boolean @default(true)
 connectionType ServerConnectionType @default(SSH_KEY)
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 sshKey SshKey? @relation(fields: [sshKeyId], references: [id], onDelete: SetNull)
 storageNode StorageNode?
 commandTargets CommandTarget[]
 metricSnapshots MetricSnapshot[]
 downloadTasks DownloadTask[]
 sourceSyncs SyncJob[] @relation("SourceSyncs")
 targetSyncs SyncJob[] @relation("TargetSyncs")
 publicUrl String? // 目标服务器公网访问地址（直连模式）
 fileProxyPort Int @default(0) // 文件代理端口（0=未启用）
 hostedActions AiHostedAction[]
 fileProxies ServerFileProxy[]

 @@index([host, port])
 @@index([enabled])
 @@map("servers")
}

model CommandRequest {
  id              String               @id @default(cuid())
  title           String
  command         String
  reason          String?
  status          CommandRequestStatus @default(PENDING_APPROVAL)
  initiatedByType ActorType
  requesterId     String
  workerId        String?
  workerHeartbeatAt DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
 requester User @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
 approvals CommandApproval[]
 targets CommandTarget[]
  executionLogs ExecutionLog[]
  deploymentRuns DeploymentRun[]
  deploymentRollbackRuns DeploymentRollbackRun[]

 @@index([status, createdAt])
 @@index([requesterId, createdAt])
 @@index([status, workerHeartbeatAt])
 @@map("command_requests")
}

model CommandApproval {
  id               String         @id @default(cuid())
  commandRequestId String
  approverId       String
  approved         Boolean
  comment          String?
  createdAt        DateTime       @default(now())
  commandRequest   CommandRequest @relation(fields: [commandRequestId], references: [id], onDelete: Cascade)
  approver         User           @relation(fields: [approverId], references: [id], onDelete: Cascade)
}

model CommandTarget {
  id               String               @id @default(cuid())
  commandRequestId String
  serverId         String
  status           CommandRequestStatus @default(PENDING_APPROVAL)
  stdout           String?
  stderr           String?
  exitCode         Int?
  startedAt        DateTime?
  finishedAt       DateTime?
 commandRequest CommandRequest @relation(fields: [commandRequestId], references: [id], onDelete: Cascade)
 server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

 @@index([serverId, status])
 @@map("command_targets")
}

model ExecutionLog {
  id               String         @id @default(cuid())
  commandRequestId String
  serverId         String?
  summary          String
  createdAt        DateTime       @default(now())
  commandRequest   CommandRequest @relation(fields: [commandRequestId], references: [id], onDelete: Cascade)
}

model StorageNode {
  id           String              @id @default(cuid())
  name         String
  driver       StorageDriver
  isDefault    Boolean             @default(false)
  basePath     String
  directAccessMode StorageAccessMode @default(PROXY)
  publicBaseUrl String?
  directAccessExpiresSeconds Int @default(300)
  host         String?
  port         Int?
  username     String?
  serverId            String?             @unique
  healthStatus        String              @default("UNKNOWN")
  lastHealthCheckAt   DateTime?
  lastHealthError     String?
  lastHealthLatencyMs Int?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  server              Server?             @relation(fields: [serverId], references: [id], onDelete: SetNull)
 fileEntries FileEntry[]
 accessGrants UserStorageAccess[]
 shareLinks ShareLink[]
 imageUploads ImageUpload[]
 mediaItems MediaItem[]
}

model UserStorageAccess {
  id            String      @id @default(cuid())
  userId        String
  storageNodeId String
  pathPrefix    String      @default("")
  canRead       Boolean     @default(true)
  canWrite      Boolean     @default(false)
  canDelete     Boolean     @default(false)
  quotaBytes    BigInt?
  maxFileBytes  BigInt?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  storageNode   StorageNode @relation(fields: [storageNodeId], references: [id], onDelete: Cascade)

  @@unique([userId, storageNodeId, pathPrefix])
  @@index([storageNodeId, pathPrefix])
  @@map("user_storage_access")
}

model FileEntry {
  id             String        @id @default(cuid())
  name           String
  entryType      FileEntryType
  mimeType       String?
  size           BigInt?
  checksumSha256 String?
  relativePath   String
  storageNodeId  String
  parentId       String?
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  storageNode    StorageNode   @relation(fields: [storageNodeId], references: [id], onDelete: Cascade)
  parent         FileEntry?    @relation("FileEntryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       FileEntry[]   @relation("FileEntryChildren")

  @@unique([storageNodeId, relativePath])
}

model AuditLog {
 id String @id @default(cuid())
 actorType ActorType
 actorId String?
 action String
 severity AuditSeverity @default(INFO)
 detail Json
 createdAt DateTime @default(now())
 actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

 @@index([createdAt])
 @@index([action, createdAt])
 @@index([actorId, createdAt])
 @@map("audit_logs")
}

enum SyncJobStatus {
  IDLE
  RUNNING
  PAUSED
  ERROR
}

enum DownloadTaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ScheduledTaskStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Job {
  id                String    @id @default(cuid())
  type              String
  title             String
  payload           Json
  status            JobStatus @default(PENDING)
  priority          Int       @default(0)
  maxAttempts       Int       @default(3)
  attempts          Int       @default(0)
  progress          String?
  result            Json?
  errorMessage      String?
  createdBy         String?
  targetStorageNodeId String?
  availableAt       DateTime  @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  workerId          String?
  workerHeartbeatAt DateTime?
  leaseExpiresAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  creator User? @relation("jobCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  events  JobEvent[]

  @@index([status, availableAt, priority, createdAt])
  @@index([status, leaseExpiresAt])
  @@index([type, status])
  @@index([createdBy, createdAt])
  @@index([targetStorageNodeId, status])
  @@map("jobs")
}

// TR-001 T13a: append-only event stream for the durable job workers so the
// operation-tasks center can show a "view events" timeline (claim, heartbeat,
// progress, completion, failure, recovery). The events are scoped to a single
// jobId and ordered by createdAt so a worker crash mid-dispatch still leaves a
// recoverable trail. Pruning is governed by `pruneJobEvents` (keepLatest +
// olderThan) and the per-job `events` index.
model JobEvent {
  id        String   @id @default(cuid())
  jobId     String
  type      String
  level     String   @default("info")
  message   String
  workerId  String?
  payload   Json?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@index([type, createdAt])
  @@map("job_events")
}

model ScheduledTask {
  id             String              @id @default(cuid())
  name           String
  cronExpression String
  command        String
  reason         String?
  status         ScheduledTaskStatus @default(ACTIVE)
  serverIds      String[]
  createdById    String?
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  lastResult     String?
  runCount       Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  creator        User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status, nextRunAt])
  @@map("scheduled_tasks")
}

// TR-023 M04: Playbook = durable chain of steps (run_command | send_notification
// | call_webhook) triggered by a scheduler. The trigger config, step chain, and
// runtime state are stored in dedicated fields rather than in the generic
// `scheduled_tasks` table so we can model multi-step runbooks with retries
// per-step, per-step timeouts, and a `dryRun` mode that walks the chain
// without side effects.
model Playbook {
  id          String   @id @default(cuid())
  name        String
  description String?
  // "cron" | "metric" — initial version. Webhook trigger ships later.
  triggerType String
  // Cron expression when triggerType="cron" (5-field standard cron), or
  // { metric: "cpu_usage" | "mem_usage" | "disk_usage", operator, threshold }
  // when triggerType="metric".
  triggerConfig Json
  // Ordered list of PlaybookStep records: { id, type, config, retry, timeoutSec }.
  // Stored as JSON to avoid an extra join table; max 32 steps enforced at the
  // zod service layer.
  steps       Json
  // Chain-wide retry budget (re-queue the whole chain on any step failure);
  // default 0 (no chain retry) so failed runs surface immediately.
  chainRetry  Int      @default(0)
  enabled     Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  runs    PlaybookRun[]

  @@index([enabled, createdAt])
  @@map("playbooks")
}

model PlaybookRun {
  id             String    @id @default(cuid())
  playbookId     String
  // "queued" | "running" | "completed" | "failed" | "cancelled"
  status         String    @default("queued")
  // True when the run was triggered via /api/playbooks/[id]/dry-run and the
  // executor skipped real side effects. Persisted so the UI can distinguish
  // "I want to see what would happen" from real runs.
  dryRun         Boolean   @default(false)
  // Free-form trigger context: cron tick id, metric reading, manual button
  // click. The executor writes a step result list back to `stepResults`.
  triggerContext Json?
  stepResults    Json?
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  playbook Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  creator User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([playbookId, createdAt])
  @@index([status, createdAt])
  @@map("playbook_runs")
}

model MetricSnapshot {
  id        String   @id @default(cuid())
  serverId  String
  cpuUsage  Float
  memUsage  Float
  diskUsage Float // max disk usage percent across mounts
  isOnline  Boolean  @default(true)
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
  @@map("metric_snapshots")
}

model AlertRule {
  id              String    @id @default(cuid())
  name            String
  metric          String // cpu_usage | mem_usage | disk_usage | server_offline
  operator        String // gt | gte | lt | lte | eq
  threshold       Float
  durationSeconds Int       @default(0) // 0 = instant alert
  serverIds       String[] // empty = all servers
  notifyChannels  String[] // ["in_app", "email", "webhook"]
  webhookUrl      String?
  cooldownMinutes Int       @default(30)
  silenceWindows  String[]  @default([]) // HH:mm-HH:mm windows, local server time
  enabled         Boolean   @default(true)
  lastMatchedAt   DateTime?
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("alert_rules")
}

model CommandTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  command     String
  rollbackCommand String?
  variables   String[] // list of {{var}} placeholders
  tags        String[]
  isBuiltin   Boolean  @default(false)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator        User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  deploymentRuns DeploymentRun[]

  @@map("command_templates")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model SyncJob {
  id             String        @id @default(cuid())
  name           String
  sourceServerId String
  sourcePath     String
  targetServerId String
  targetPath     String
  syncType       String        @default("MIRROR")
  status         SyncJobStatus @default(IDLE)
  schedule       String?
  lastSyncAt     DateTime?
  lastSyncResult String?
  deleteOrphans  Boolean       @default(false)
  compress       Boolean       @default(false)
  createdBy      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sourceServer Server    @relation("SourceSyncs", fields: [sourceServerId], references: [id], onDelete: Cascade)
  targetServer Server    @relation("TargetSyncs", fields: [targetServerId], references: [id], onDelete: Cascade)
  creator      User?     @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  syncLogs     SyncLog[]

  @@map("sync_jobs")
}

model SyncLog {
  id               String    @id @default(cuid())
  syncJobId        String
  status           String
  filesScanned     Int       @default(0)
  filesTransferred Int       @default(0)
  filesDeleted     Int       @default(0)
  bytesTransferred String    @default("0")
  durationMs       Int       @default(0)
  errorMessage     String?
  startedAt        DateTime  @default(now())
  completedAt      DateTime?

  syncJob SyncJob @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

model DownloadTask {
  id           String             @id @default(cuid())
  url          String
  serverId     String
  targetPath   String
  fileName     String?
  status       DownloadTaskStatus @default(PENDING)
  progress     String?
  pid          Int?
  errorMessage String?
  relayMode    Boolean            @default(false)
  createdBy    String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  /**
   * ── Aria2 RPC integration ──────────────────────
   */
  aria2Gid String?

  /**
   * ── Enhanced metadata ─────────────────────────
   */
  category       String?
  maxSpeedKb     Int?
  totalBytes     String?
  completedBytes String?
  downloadSpeed  String?
  fileSize       String?
  isBatch        Boolean @default(false)
  batchUrls      String?

 server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
 creator User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

 @@index([serverId, status])
 @@index([status, createdAt])
 @@map("download_tasks")
}

model ShareLink {
  id            String        @id @default(cuid())
  tokenHash     String        @unique
  storageNodeId String
  path          String
  entryType     FileEntryType @default(FILE)
  name          String?
  expiresAt     DateTime?
  revokedAt     DateTime?
  accessCount   Int           @default(0)
  createdBy     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  storageNode StorageNode @relation(fields: [storageNodeId], references: [id], onDelete: Cascade)
  creator     User?       @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([storageNodeId, path])
  @@index([expiresAt])
  @@map("share_links")
}

model BackupRecord {
  id           String    @id @default(cuid())
  type         String
  status       String    @default("PENDING")
  filePath     String
  fileSize     String?
  note         String?
  errorMessage String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?

  creator User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("backup_records")
}

model DeploymentRun {
  id               String    @id @default(cuid())
  templateId       String
  commandRequestId String?
  snapshotId       String?   @unique
  rollbackOfRunId  String?
  status           String    @default("PENDING")
  variables        Json
  renderedCommand  String
  serverIds        String[]
  createdBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?
  errorMessage     String?

  template CommandTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  commandRequest CommandRequest? @relation(fields: [commandRequestId], references: [id], onDelete: SetNull)
  creator  User?           @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  snapshot DeploymentSnapshot? @relation("deploymentSnapshotSource", fields: [snapshotId], references: [id], onDelete: SetNull)
  rollbackOf DeploymentRun? @relation("deploymentRollbackRuns", fields: [rollbackOfRunId], references: [id], onDelete: SetNull)
  rollbackRuns DeploymentRun[] @relation("deploymentRollbackRuns")
  rollbackAttempts DeploymentRollbackRun[] @relation("deploymentRollbackSource")

  @@index([status, createdAt])
  @@index([snapshotId])
  @@index([rollbackOfRunId])
  @@map("deployment_runs")
}

model DeploymentSnapshot {
  id              String   @id @default(cuid())
  sourceRunId     String?  @unique
  templateId      String
  templateName    String
  deployCommand   String
  rollbackCommand String?
  variables       Json
  serverIds       String[]
  createdBy       String?
  createdAt       DateTime @default(now())

  sourceRun DeploymentRun? @relation("deploymentSnapshotSource")
  rollbackRuns DeploymentRollbackRun[]

  @@index([templateId, createdAt])
  @@index([createdAt])
  @@map("deployment_snapshots")
}

model DeploymentRollbackRun {
  id               String    @id @default(cuid())
  sourceRunId      String
  snapshotId       String
  commandRequestId String?
  status           String    @default("PENDING")
  rollbackCommand  String
  serverIds        String[]
  reason           String?
  createdBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?
  errorMessage     String?

  sourceRun DeploymentRun @relation("deploymentRollbackSource", fields: [sourceRunId], references: [id], onDelete: Cascade)
  snapshot DeploymentSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  commandRequest CommandRequest? @relation(fields: [commandRequestId], references: [id], onDelete: SetNull)
  creator User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([sourceRunId, createdAt])
  @@index([snapshotId, createdAt])
  @@index([status, createdAt])
  @@map("deployment_rollback_runs")
}

model Snippet {
  id          String   @id @default(cuid())
  title       String
  description String?
  language    String   @default("text")
  content     String
  tags        String[]
  isPrivate   Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([createdBy, updatedAt])
  @@map("snippets")
}

model ApiToken {
  id          String    @id @default(cuid())
  name        String
  tokenHash   String    @unique
  tokenPrefix String
  tokenSuffix String
  scopes      String[]
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  creator     User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([createdBy, revokedAt])
  @@map("api_tokens")
}

model Announcement {
  id        String    @id @default(cuid())
  title     String
  body      String
  level     String    @default("info")
  pinned    Boolean   @default(false)
  published Boolean   @default(false)
  startsAt  DateTime  @default(now())
  expiresAt DateTime?
  createdBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  creator   User?     @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([published, pinned, startsAt])
  @@map("announcements")
}

model MediaItem {
  id            String   @id @default(cuid())
  fileEntryId   String?  @unique
  storageNodeId String
  name          String
  relativePath  String
  mimeType      String
  mediaType     String
  size          BigInt?
  tags          String[]
  favorite      Boolean  @default(false)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  creator       User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  storageNode   StorageNode? @relation(fields: [storageNodeId], references: [id], onDelete: Restrict)

  @@index([storageNodeId, mediaType])
  @@index([favorite, updatedAt])
  @@index([mediaType, createdAt])
  @@index([storageNodeId])
  @@map("media_items")
}

model Ticket {
  id          String          @id @default(cuid())
  title       String
  description String
  status      String          @default("OPEN")
  priority    String          @default("NORMAL")
  createdBy   String
  assigneeId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  closedAt    DateTime?
  creator     User            @relation("TicketCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  assignee    User?           @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    TicketComment[]

  @@index([status, priority, createdAt])
  @@index([createdBy])
  @@index([assigneeId])
  @@map("tickets")
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([authorId])
  @@map("ticket_comments")
}

model DeploymentExport {
  id        String   @id @default(cuid())
  name      String
  kind      String   @default("PORTABLE_PACKAGE")
  manifest  Json
  files     Json
  createdBy String?
  createdAt DateTime @default(now())
  creator   User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

 @@index([createdAt])
 @@map("deployment_exports")
}

enum AiProviderType {
 OPENAI
 OPENAI_COMPATIBLE
 ANTHROPIC
 GOOGLE
 CUSTOM
}

model AiProvider {
 id String @id @default(cuid())
 name String
 type AiProviderType @default(OPENAI_COMPATIBLE)
 apiKey String
 baseUrl String @default("https://api.openai.com/v1")
 defaultModel String @default("gpt-4o")
 availableModels String @default("[]")
 isDefault Boolean @default(false)
 enabled Boolean @default(true)
 settings Json @default("{}")
 createdBy String
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)
 conversations AiConversation[]

 @@unique([createdBy, name])
 @@index([enabled])
 @@map("ai_providers")
}

model AiConversation {
 id String @id @default(cuid())
 title String @default("新对话")
 providerId String
 model String
 systemPrompt String?
 temperature Float @default(0.7)
 maxTokens Int @default(4096)
 topP Float @default(1.0)
 frequencyPenalty Float @default(0.0)
 presencePenalty Float @default(0.0)
 enableVision Boolean @default(false)
 hostingEnabled Boolean @default(false) // AI托管模式：允许AI操作VPS
 createdBy String
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 provider AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
 creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)
 messages AiMessage[]
 hostedActions AiHostedAction[]

 @@index([createdBy, updatedAt])
 @@map("ai_conversations")
}

model AiMessage {
 id String @id @default(cuid())
 conversationId String
 role String // "user" | "assistant" | "system" | "tool"
 content String
 reasoningContent String?
 imageUrls String @default("[]")
 toolCalls String @default("[]") // JSON: [{id, type, function: {name, arguments}}]
 toolCallId String? // 用于 role=tool 时关联的 tool_call id
 model String?
 inputTokens Int?
 outputTokens Int?
 latencyMs Int?
 createdAt DateTime @default(now())
 conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
 hostedActions AiHostedAction[]

 @@index([conversationId, createdAt])
 @@index([toolCallId])
 @@map("ai_messages")
}

model QuickService {
  id           String   @id @default(cuid())
  slug         String   @unique // e.g. "alist", "emby", "jellyfin"
  name         String   // display name e.g. "AList 云盘"
  category     String   @default("other") // storage|media|devtools|network|other
  icon         String   @default("☁️") // emoji icon for sidebar
  description  String   @default("")
  image        String   // docker image e.g. "xhofe/alist:latest"
  port         Int      // host port to expose
  path         String   @default("") // reverse proxy path e.g. "/files-proxy/"
  internalPort Int?     // container port for the primary host port mapping
  extraPortsJson String @default("[]") // JSON: [{host:9001, container:9001}]
  command      String?  // optional command appended to docker run image
  envJson      String   @default("{}") // JSON string of env vars
  volumesJson  String   @default("[]") // JSON: [{host:"/opt/alist/data", container:"/opt/alist/data"}]
  status       String   @default("available") // available|installing|running|stopped|error
  containerId  String?  // docker container ID when running
  error        String?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

 @@index([category, status])
 @@map("quick_services")
}

// ── Image Hosting (图床) ──────────────────────────────────────────

model ImageUpload {
 id          String   @id @default(cuid())
 filename    String   // original filename
 storageKey  String   // stored filename (uuid-based)
 mimeType    String
 sizeBytes   Int
 width       Int?
 height      Int?
 checksum    String?  // sha256
 album       String?  // optional album grouping
 isPublic    Boolean  @default(true)
 storageNodeId String? // optional: link to cloud storage node
 relativePath  String? // path within the storage node
 userId      String
 createdAt   DateTime @default(now())

 user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 storageNode StorageNode? @relation(fields: [storageNodeId], references: [id], onDelete: SetNull)

 @@index([userId, createdAt])
 @@index([album])
 @@index([isPublic, createdAt])
 @@map("image_uploads")
}

model AiHostedAction {
 id String @id @default(cuid())
 conversationId String
 messageId String
 serverId String?
 actionType String // get_status | read_logs | execute_command | restart_service | modify_config | deploy_docker
 actionName String // 人类可读的操作名称
 params String @default("{}") // JSON: 操作参数
 status AiHostedActionStatus @default(PENDING_APPROVAL)
 riskLevel String @default("medium") // low | medium | high | critical
 autoApproved Boolean @default(false) // 是否自动批准（安全操作）
 result String? // JSON: 执行结果
 errorMessage String?
 requesterId String // AI发起时为system user id
 approverId String?
 createdAt DateTime @default(now())
 approvedAt DateTime?
 executedAt DateTime?
 completedAt DateTime?

 conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
 message AiMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
 server Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)
 requester User @relation("AiHostedRequester", fields: [requesterId], references: [id], onDelete: Cascade)
 approver User? @relation("AiHostedApprover", fields: [approverId], references: [id], onDelete: SetNull)

 @@index([status, createdAt])
 @@index([conversationId, createdAt])
 @@index([serverId, status])
 @@map("ai_hosted_actions")
}

model ServerFileProxy {
 id String @id @default(cuid())
 serverId String
 proxyType String @default("python_http") // python_http | node_agent | nginx
 port Int
 status String @default("starting") // starting | running | stopped | error
 pid Int? // 进程ID
 accessToken String? // 一次性访问令牌
 expiresAt DateTime?
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt

 server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

 @@unique([serverId, proxyType])
 @@index([serverId, status])
 @@map("server_file_proxies")
}

// ── App Store: External Catalog Sources ──────────────────────────────

model AppSource {
	id String @id @default(cuid())
	name String @unique // e.g. "linuxserver", "coolify", "caprover"
	displayName String @map("display_name") // e.g. "LinuxServer.io"
	url String // source API endpoint or repo URL
	type String @default("json") // json | github | custom
	enabled Boolean @default(true)
	/** Cron-style sync interval, e.g. "daily", "hourly", or ISO duration */
	syncInterval String @default("daily") @map("sync_interval")
	lastSyncAt DateTime? @map("last_sync_at")
	lastSyncStatus String? @map("last_sync_status") // success | error
	lastSyncError String? @map("last_sync_error")
	syncCount Int @default(0) @map("sync_count")
	/** JSON: source-specific config (e.g. GitHub repo, branch, path) */
	configJson String @default("{}") @map("config_json")
	createdAt DateTime @default(now()) @map("created_at")
	updatedAt DateTime @updatedAt @map("updated_at")

	apps AppSourceApp[]

	@@map("app_sources")
}

model AppSourceApp {
	id String @id @default(cuid())
	sourceId String @map("source_id")
	source AppSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
	/** Unique slug within source, prefixed with source name: e.g. "linuxserver-sonarr" */
	slug String @unique
	name String
	category String @default("other")
	icon String @default("📦")
	description String @default("")
	image String
	defaultPort Int @default(8080) @map("default_port")
	internalPort Int? @map("internal_port")
	path String @default("/")
	envJson String @default("{}") @map("env_json")
	volumesJson String @default("[]") @map("volumes_json")
	command String?
	extraPortsJson String @default("[]") @map("extra_ports_json")
	/** Raw data from source for reference/debugging */
	rawJson String? @map("raw_json")
	/** Version/tag from source for change detection */
	sourceVersion String? @map("source_version")
	createdAt DateTime @default(now()) @map("created_at")
	updatedAt DateTime @updatedAt @map("updated_at")

	@@index([sourceId, category])
	@@index([category])

	@@map("app_source_apps")
}