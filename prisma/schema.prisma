// ── 55c (TR-009): Media resumable upload sessions ────────────────
//
// Tracks a chunked / resumable upload to /api/images/upload. The client
// initialises a session, uploads chunks one at a time, then asks the server
// to assemble + process (thumbnail / webp / avif) + create the final
// ImageUpload row.
//
// Lifecycle:
//   PENDING → UPLOADING (first chunk arrives) → COMPLETED (assemble ok)
//   any state → CANCELLED (client cancels, or server TTL expired)
//   any state → FAILED (assembly error)
//
// Chunk storage lives in /tmp under UPLOAD_TMP_DIR/<sessionId>/chunk-N.
// On COMPLETED, chunks are concatenated into the final image buffer and
// handed off to the existing image pipeline; on CANCELLED/expired, the temp
// dir is removed.
model MediaUploadSession {
  id             String                   @id @default(cuid())
  userId         String
  filename       String
  mimeType       String
  totalSize      BigInt
  chunkSize      Int
  totalChunks    Int
  receivedChunks Int[]                    @default([])
  storageNodeId  String?
  relativePath   String?
  status         MediaUploadSessionStatus @default(PENDING)
  resultImageId  String? // populated when status = COMPLETED
  checksum       String? // sha256 of assembled file
  errorMessage   String?
  expiresAt      DateTime
  completedAt    DateTime? // populated when status = COMPLETED
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storageNode StorageNode? @relation(fields: [storageNodeId], references: [id], onDelete: SetNull)
  resultImage ImageUpload? @relation(fields: [resultImageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, expiresAt])
  @@map("media_upload_sessions")
}

enum MediaUploadSessionStatus {
  PENDING
  UPLOADING
  COMPLETED
  CANCELLED
  FAILED
}

