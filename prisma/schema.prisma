generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING_PASSWORD_RESET
}

enum ServerConnectionType {
  SSH_KEY
  PASSWORD
}

enum CommandRequestStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ActorType {
  USER
  ASSISTANT
  SYSTEM
}

enum StorageDriver {
  LOCAL
  SFTP
}

enum StorageAccessMode {
  PROXY
  DIRECT
  AUTO
}

enum FileEntryType {
  FILE
  DIRECTORY
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AiHostedActionStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXECUTING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id                     String                  @id @default(cuid())
  username               String                  @unique
  displayName            String?
  passwordHash           String
  status                 UserStatus              @default(PENDING_PASSWORD_RESET)
  mustChangePassword     Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  roles                  UserRole[]
  storageAccess          UserStorageAccess[]
  commandRequests        CommandRequest[]        @relation("requester")
  jobs                   Job[]                   @relation("jobCreator")
  approvals              CommandApproval[]
  auditLogs              AuditLog[]
  sshKeys                SshKey[]                @relation("SshKeyCreator")
  notifications          Notification[]
  scheduledTasks         ScheduledTask[]
  playbooks              Playbook[]
  playbookRuns           PlaybookRun[]
  commandTemplates       CommandTemplate[]
  downloadTasks          DownloadTask[]
  syncJobs               SyncJob[]
  shareLinks             ShareLink[]
  backupRecords          BackupRecord[]
  backupSchedules        BackupSchedule[]
  vpsBackupSchedules     VpsBackupSchedule[]
  vpsBackupRecords       VpsBackupRecord[]
  deploymentRuns         DeploymentRun[]
  deploymentRollbackRuns DeploymentRollbackRun[]
  snippets               Snippet[]
  apiTokens              ApiToken[]
  announcements          Announcement[]
  mediaItems             MediaItem[]
  tickets                Ticket[]                @relation("TicketCreator")
  alertIncidentsAcknowledged AlertIncident[]       @relation("AlertIncidentAcknowledger")
  assignedTickets        Ticket[]                @relation("TicketAssignee")
  ticketComments         TicketComment[]
  imageUploads           ImageUpload[]
  deploymentExports      DeploymentExport[]
  aiProviders            AiProvider[]
  aiConversations        AiConversation[]
  knowledgeBasesCreated  KnowledgeBase[]     @relation("KnowledgeBaseCreator")
  knowledgeDocsCreated   KnowledgeDocument[] @relation("KnowledgeDocumentCreator")
  aiHostedRequests       AiHostedAction[]        @relation("AiHostedRequester")
  aiHostedApprovals      AiHostedAction[]        @relation("AiHostedApprover")
  costEntries            CostEntry[]             @relation("CostEntryCreatedBy")
  cloudBillingAccounts   CloudBillingAccount[]   @relation("CloudBillingAccountCreatedBy")
  itsmConnections        ItsmConnection[]         @relation("ItsmConnectionCreatedBy")
  aiOpsLogs              AiOpsLog[]              @relation("AiOpsLogTriggeredBy")
  mediaUploadSessions    MediaUploadSession[]
  fileVersions           FileVersion[]
  ownedTeams             Team[]                  @relation("TeamOwner")
  teamMemberships        TeamMember[]
  currentTeamId          String?
  currentTeam            Team?                   @relation("UserCurrentTeam", fields: [currentTeamId], references: [id], onDelete: SetNull)
  twoFactorEnabled       Boolean                 @default(false)
  twoFactorSecret        String?
  preferences            Json?
  roleTemplates          RoleTemplate[]          @relation("RoleTemplateCreator")

  @@map("User")
}

model Team {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  description     String?
  ownerId         String?
  owner           User?            @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members         TeamMember[]
  currentFor      User[]           @relation("UserCurrentTeam")
  servers         Server[]         @relation("TeamServers")
  storageNodes    StorageNode[]    @relation("TeamStorageNodes")
  commandRequests CommandRequest[] @relation("TeamCommandRequests")
  downloadTasks   DownloadTask[]   @relation("TeamDownloadTasks")
  syncJobs        SyncJob[]        @relation("TeamSyncJobs")
  backupRecords   BackupRecord[]   @relation("TeamBackupRecords")
  backupSchedules BackupSchedule[] @relation("TeamBackupSchedules")
  deploymentRuns  DeploymentRun[]  @relation("TeamDeploymentRuns")
  jobs            Job[]            @relation("TeamJobs")
  scheduledTasks  ScheduledTask[]  @relation("TeamScheduledTasks")
  shareLinks      ShareLink[]      @relation("TeamShareLinks")
  tickets         Ticket[]         @relation("TeamTickets")
  playbooks       Playbook[]       @relation("TeamPlaybooks")
  playbookRuns    PlaybookRun[]    @relation("TeamPlaybookRuns")
  notifications   Notification[]   @relation("TeamNotifications")
  auditLogs       AuditLog[]       @relation("TeamAuditLogs")
  knowledgeBases  KnowledgeBase[]  @relation("TeamKnowledgeBases")
  cloudBillingAccounts CloudBillingAccount[] @relation("TeamCloudBillingAccounts")
  alertRules          AlertRule[]         @relation("TeamAlertRules")
  costEntries         CostEntry[]         @relation("TeamCostEntries")
  costBudgets         CostBudget[]        @relation("TeamCostBudgets")
  sshKeys             SshKey[]           @relation("TeamSshKeys")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  teamId   String
  userId   String
  role     String   @default("member") // owner|admin|member
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]

  @@map("Role")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  roles       RolePermission[]

  @@map("Permission")
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("UserRole")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("RolePermission")
}

model SshKey {
  id          String   @id @default(cuid())
  name        String
  fingerprint String   @unique
  publicKey   String
  privateKey  String?
  passphrase  String?
  description String?
  createdById String?
  teamId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User?    @relation("SshKeyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  team        Team?    @relation("TeamSshKeys", fields: [teamId], references: [id], onDelete: SetNull)
  servers     Server[]

  @@index([createdById])
  @@index([teamId])
  @@map("SshKey")
}

model Server {
  id                 String                 @id @default(cuid())
  name               String
  host               String
  port               Int                    @default(22)
  username           String
  sshKeyId           String?
  password           String?
  description        String?
  tags               String[]
  enabled            Boolean                @default(true)
  connectionType     ServerConnectionType   @default(SSH_KEY)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  sshKey             SshKey?                @relation(fields: [sshKeyId], references: [id], onDelete: SetNull)
  storageNode        StorageNode?
  quickServices      QuickService[]
  commandTargets     CommandTarget[]
  metricSnapshots    MetricSnapshot[]
  trafficSnapshots   TrafficSnapshot[]
  downloadTasks      DownloadTask[]
  sourceSyncs        SyncJob[]              @relation("SourceSyncs")
  targetSyncs        SyncJob[]              @relation("TargetSyncs")
  publicUrl          String? // 目标服务器公网访问地址（直连模式）
  fileProxyPort      Int                    @default(0) // 文件代理端口（0=未启用）
  osDialect          String? // TR-041: JSON 序列化的 OsDialect（包管理器/服务管理器/路径等）
  osInfo             String? // TR-041: /etc/os-release 原始摘要（distro name + version）
  hostKeySha256      String? // SHA256 SSH host key fingerprint used for strict host verification
  costAutoSync       Boolean                @default(false) // TR-031: 是否自动同步 VPS 月费到成本条目
  costMonthlyAmount  Decimal?               @db.Decimal(12, 2) // TR-031: VPS 月费
  costCurrency       String                 @default("CNY") // TR-031: VPS 月费币种
  costProvider       String? // TR-031: 账单提供方（为空时使用节点名称）
  costLastSyncedAt   DateTime? // TR-031: 最近一次自动同步时间
  teamId             String? // TR-030: 多租户资源隔离
  team               Team?                  @relation("TeamServers", fields: [teamId], references: [id], onDelete: SetNull)
  hostedActions      AiHostedAction[]
  fileProxies        ServerFileProxy[]
  vpsBackupSchedules VpsBackupSchedule[]
  vpsBackupRecords   VpsBackupRecord[]
  uptimeSnapshots    ServerUptimeSnapshot[]

  @@index([host, port])
  @@index([enabled])
  @@index([teamId])
  @@map("servers")
}

model CommandRequest {
  id                     String                  @id @default(cuid())
  title                  String
  command                String
  reason                 String?
  status                 CommandRequestStatus    @default(PENDING_APPROVAL)
  initiatedByType        ActorType
  requesterId            String
  workerId               String?
  workerHeartbeatAt      DateTime?
  idempotencyKey         String?                 @unique
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  requester              User                    @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  approvals              CommandApproval[]
  targets                CommandTarget[]
  executionLogs          ExecutionLog[]
  deploymentRuns         DeploymentRun[]
  deploymentRollbackRuns DeploymentRollbackRun[]

  teamId String? // TR-030: 多租户资源隔离
  team   Team?   @relation("TeamCommandRequests", fields: [teamId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([requesterId, createdAt])
  @@index([status, workerHeartbeatAt])
  @@index([teamId])
  @@map("command_requests")
}

model CommandApproval {
  id               String         @id @default(cuid())
  commandRequestId String
  approverId       String
  approved         Boolean
  comment          String?
  createdAt        DateTime       @default(now())
  commandRequest   CommandRequest @relation(fields: [commandRequestId], references: [id], onDelete: Cascade)
  approver         User           @relation(fields: [approverId], references: [id], onDelete: Cascade)

  @@index([commandRequestId])
  @@index([approverId])
  @@map("command_approvals")
}

model CommandTarget {
  id               String               @id @default(cuid())
  commandRequestId String
  serverId         String
  status           CommandRequestStatus @default(PENDING_APPROVAL)
  stdout           String?
  stderr           String?
  exitCode         Int?
  startedAt        DateTime?
  finishedAt       DateTime?
  commandRequest   CommandRequest       @relation(fields: [commandRequestId], references: [id], onDelete: Cascade)
  server           Server               @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, status])
  @@index([commandRequestId])
  @@map("command_targets")
}

model ExecutionLog {
  id               String         @id @default(cuid())
  commandRequestId String
  serverId         String?
  summary          String
  createdAt        DateTime       @default(now())
  commandRequest   CommandRequest @relation(fields: [commandRequestId], references: [id], onDelete: Cascade)

  @@index([commandRequestId])
  @@index([serverId])
  @@map("execution_logs")
}

model StorageNode {
  id                         String               @id @default(cuid())
  name                       String
  driver                     StorageDriver
  isDefault                  Boolean              @default(false)
  basePath                   String
  directAccessMode           StorageAccessMode    @default(PROXY)
  publicBaseUrl              String?
  directAccessExpiresSeconds Int                  @default(300)
  host                       String?
  port                       Int?
  username                   String?
  serverId                   String?              @unique
  healthStatus               String               @default("UNKNOWN")
  lastHealthCheckAt          DateTime?
  lastHealthError            String?
  lastHealthLatencyMs        Int?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  hostKeySha256              String? // SHA256 SSH host key fingerprint used for strict host verification
  server                     Server?              @relation(fields: [serverId], references: [id], onDelete: SetNull)
  fileEntries                FileEntry[]
  accessGrants               UserStorageAccess[]
  shareLinks                 ShareLink[]
  imageUploads               ImageUpload[]
  mediaItems                 MediaItem[]
  mediaUploadSessions        MediaUploadSession[]
  fileVersions               FileVersion[]

  teamId String? // TR-030: 多租户资源隔离
  team   Team?   @relation("TeamStorageNodes", fields: [teamId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@map("StorageNode")
}

model UserStorageAccess {
  id            String      @id @default(cuid())
  userId        String
  storageNodeId String
  pathPrefix    String      @default("")
  canRead       Boolean     @default(true)
  canWrite      Boolean     @default(false)
  canDelete     Boolean     @default(false)
  quotaBytes    BigInt?
  maxFileBytes  BigInt?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  storageNode   StorageNode @relation(fields: [storageNodeId], references: [id], onDelete: Cascade)

  @@unique([userId, storageNodeId, pathPrefix])
  @@index([storageNodeId, pathPrefix])
  @@map("user_storage_access")
}

model FileEntry {
  id             String        @id @default(cuid())
  name           String
  entryType      FileEntryType
  mimeType       String?
  size           BigInt?
  checksumSha256 String?
  relativePath   String
  storageNodeId  String
  parentId       String?
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  storageNode    StorageNode   @relation(fields: [storageNodeId], references: [id], onDelete: Cascade)
  parent         FileEntry?    @relation("FileEntryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       FileEntry[]   @relation("FileEntryChildren")
  versions       FileVersion[]

  @@unique([storageNodeId, relativePath])
  @@index([parentId])
  @@index([storageNodeId, entryType, isDeleted])
  @@map("file_entries")
}

enum FileVersionReason {
  UPLOAD
  EDIT
  MANUAL
  RESTORE_POINT
}

/// Immutable historical snapshot of a file body, stored on the control plane.
/// Snapshots are taken before overwrite (upload/edit/restore) so users can
/// download or restore previous content. Blobs live under FILE_VERSION_DIR.
model FileVersion {
  id              String            @id @default(cuid())
  fileEntryId     String
  storageNodeId   String
  versionNumber   Int
  name            String
  relativePath    String
  mimeType        String?
  sizeBytes       BigInt
  checksumSha256  String
  /// Absolute-or-managed relative blob path under FILE_VERSION_DIR
  blobRelativePath String
  reason          FileVersionReason @default(UPLOAD)
  note            String?
  createdByUserId String?
  createdAt       DateTime          @default(now())

  fileEntry   FileEntry   @relation(fields: [fileEntryId], references: [id], onDelete: Cascade)
  storageNode StorageNode @relation(fields: [storageNodeId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([fileEntryId, versionNumber])
  @@index([fileEntryId, createdAt])
  @@index([storageNodeId, createdAt])
  @@map("file_versions")
}

model AuditLog {
  id        String        @id @default(cuid())
  actorType ActorType
  actorId   String?
  action    String
  severity  AuditSeverity @default(INFO)
  detail    Json
  createdAt DateTime      @default(now())
  actor     User?         @relation(fields: [actorId], references: [id], onDelete: SetNull)

  teamId String? // TR-030: 多租户资源隔离
  team   Team?   @relation("TeamAuditLogs", fields: [teamId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([teamId])
  @@map("audit_logs")
}

enum SyncJobStatus {
  IDLE
  RUNNING
  PAUSED
  ERROR
}

enum DownloadTaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ScheduledTaskStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Job {
  id                  String    @id @default(cuid())
  type                String
  title               String
  payload             Json
  status              JobStatus @default(PENDING)
  priority            Int       @default(0)
  maxAttempts         Int       @default(3)
  attempts            Int       @default(0)
  progress            String?
  result              Json?
  errorMessage        String?
  createdBy           String?
  targetStorageNodeId String?
  availableAt         DateTime  @default(now())
  startedAt           DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  workerId            String?
  workerHeartbeatAt   DateTime?
  leaseExpiresAt      DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  creator User?      @relation("jobCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  events  JobEvent[]

  teamId String? // TR-030: 多租户资源隔离
  team   Team?   @relation("TeamJobs", fields: [teamId], references: [id], onDelete: SetNull)

  @@index([status, availableAt, priority, createdAt])
  @@index([status, leaseExpiresAt])
  @@index([type, status])
  @@index([createdBy, createdAt])
  @@index([targetStorageNodeId, status])
  @@index([teamId])
  @@map("jobs")
}

// TR-001 T13a: append-only event stream for the durable job workers so the
// operation-tasks center can show a "view events" timeline (claim, heartbeat,
// progress, completion, failure, recovery). The events are scoped to a single
// jobId and ordered by createdAt so a worker crash mid-dispatch still leaves a
// recoverable trail. Pruning is governed by `pruneJobEvents` (keepLatest +
// olderThan) and the per-job `events` index.
model JobEvent {
  id        String   @id @default(cuid())
  jobId     String
  type      String
  level     String   @default("info")
  message   String
  workerId  String?
  payload   Json?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@index([type, createdAt])
  @@map("job_events")
}

model ScheduledTask {
  id             String              @id @default(cuid())
  name           String
  cronExpression String
  command        String
  reason         String?
  status         ScheduledTaskStatus @default(ACTIVE)
  serverIds      String[]
  createdById    String?
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  lastResult     String?
  runCount       Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  creator        User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)

  teamId String? // TR-030: 多租户资源隔离
  team   Team?   @relation("TeamScheduledTasks", fields: [teamId], references: [id], onDelete: SetNull)

  @@index([status, nextRunAt])
  @@index([teamId])
  @@map("scheduled_tasks")
}

// TR-023 M04: Playbook = durable chain of steps (run_command | send_notification
// | call_webhook) triggered by a scheduler. The trigger config, step chain, and
// runtime state are stored in dedicated fields rather than in the generic
// `scheduled_tasks` table so we can model multi-step runbooks with retries
// per-step, per-step timeouts, and a `dryRun` mode that walks the chain
// without side effects.
model Playbook {
  id            String   @id @default(cuid())
  name          String
  description   String?
  // "cron" | "metric" — initial version. Webhook trigger ships later.
  triggerType   String
  // Cron expression when triggerType="cron" (5-field standard cron), or
  // { metric: "cpu_usage" | "mem_usage" | "disk_usage", operator, threshold }
  // when triggerType="metric".
  triggerConfig Json
  // Ordered list of PlaybookStep records: { id, type, config, retry, timeoutSec }.
  // Stored as JSON to avoid an extra join table; max 32 steps enforced at the
  // zod service layer.
  steps         Json
  // Chain-wide retry budget (re-queue the whole chain on any step failure);
  // default 0 (no chain retry) so failed runs surface immediately.
  chainRetry    Int      @default(0)
  enabled       Boolean  @default(true)
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creator User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  runs    PlaybookRun[]

  teamId String? // TR-030: 多租户资源隔离
  team   Team?   @relation("TeamPlaybooks", fields: [teamId], references: [id], onDelete: SetNull)

  @@index([enabled, createdAt])
  @@index([teamId])
  @@map("playbooks")
}

model PlaybookRun {
  id             String    @id @default(cuid())
  playbookId     String
  // "queued" | "running" | "completed" | "failed" | "cancelled"
  status         String    @default("queued")
  // True when the run was triggered via /api/playbooks/[id]/dry-run and the
  // executor skipped real side effects. Persisted so the UI can distinguish
  // "I want to see what would happen" from real runs.
  dryRun         Boolean   @default(false)
  // Free-form trigger context: cron tick id, metric reading, manual button
  // click. The executor writes a step result list back to `stepResults`.
  triggerContext Json?
  stepResults    Json?
  errorMessage   String?
  jobId          String?   @unique
  executionState Json?
  version        Int       @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  playbook Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  creator  User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  teamId String? // TR-030: 多租户资源隔离
  team   Team?   @relation("TeamPlaybookRuns", fields: [teamId], references: [id], onDelete: SetNull)

  @@index([playbookId, createdAt])
  @@index([status, createdAt])
  @@index([teamId])
  @@map("playbook_runs")
}

model MetricSnapshot {
  id        String   @id @default(cuid())
  serverId  String
  cpuUsage  Float
  memUsage  Float
  diskUsage Float // max disk usage percent across mounts
  isOnline  Boolean  @default(true)
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
  @@index([createdAt])
  @@map("metric_snapshots")
}

model TrafficSnapshot {
  id        String   @id @default(cuid())
  /**
   * "local" for the app host, or "server" for a managed VPS sampled over SSH.
   */
  source    String
  serverId  String?
  iface     String
  rxBytes   BigInt
  txBytes   BigInt
  rxRateBps Float    @default(0)
  txRateBps Float    @default(0)
  sampledAt DateTime @default(now())

  server Server? @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([source, iface, sampledAt])
  @@index([serverId, iface, sampledAt])
  @@map("traffic_snapshots")
}

model AlertRule {
  id                 String    @id @default(cuid())
  name               String
  metric             String // cpu_usage | mem_usage | disk_usage | server_offline
  operator           String // gt | gte | lt | lte | eq
  threshold          Float
  durationSeconds    Int       @default(0) // 0 = instant alert
  serverIds          String[] // empty = all servers
  notifyChannels     String[] // ["in_app", "email", "webhook"]
  webhookUrl         String?
  playbookIds        String[]  @default([]) // TR-023: playbooks to run when this alert triggers
  cooldownMinutes    Int       @default(30)
  silenceWindows     String[]  @default([]) // HH:mm-HH:mm windows, local server time
  /// Minutes without acknowledgement before escalating to on-call / L2 notify
  escalationMinutes  Int       @default(30)
  /// Preferred on-call user IDs (routed first for in-app / ack ownership)
  onCallUserIds      String[]  @default([])
  enabled            Boolean   @default(true)
  lastMatchedAt      DateTime?
