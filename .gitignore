# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.npm/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
*.key
*.ppk
*.pub
id_rsa*
id_ed25519*

# debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# browser test artifacts (also keep Tailwind v4 source discovery away from traces)
test-results/
playwright-report/
.playwright-output/
login-dark.png
login-light.png

# env files / local secrets
.env*
!.env.example
*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local runtime data (created per deployment host)
/storage/*
!/storage/.gitkeep
/tmp/*
!/tmp/.gitkeep
/uploads/*
!/uploads/.gitkeep
/downloads/*
!/downloads/.gitkeep
/backups/*
!/backups/.gitkeep
/logs/*
!/logs/.gitkeep

# local scripts / scratch files
_test_*.js
_test_*.ts
check_*.py
make_*.py

# databases and generated dumps / archives
*.db
*.sqlite
*.sqlite3
*.dump
*.sql
!prisma/migrations/**/migration.sql
*.sql.gz
*.tar.gz
*.zip

# Hermes agent local files (scripts, plans, etc.)
.hermes/
.cache/
.config/
