[Unit]
Description=whrkhldsb Next.js application
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/whrkhldsb
EnvironmentFile=/root/whrkhldsb/.env.local
Environment=NODE_ENV=production
Environment=PATH=/root/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/root/.local/bin/npm run start
Restart=always
RestartSec=5
User=root
Group=root

[Install]
WantedBy=multi-user.target
