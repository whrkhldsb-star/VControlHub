[Unit]
Description=whrkhldsb Next.js App
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/root/whrkhldsb
EnvironmentFile=/root/whrkhldsb/.env.local
ExecStart=/root/.local/bin/node /root/whrkhldsb/node_modules/.bin/next start -p 3000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
